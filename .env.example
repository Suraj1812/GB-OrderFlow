NODE_ENV=development
APP_VERSION=1.0.0
API_VERSION=v1
HOST=127.0.0.1
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gb_orderflow?schema=public
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_ORIGIN=http://127.0.0.1:5173
API_ORIGIN=http://127.0.0.1:4000
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
DOWNLOAD_TOKEN_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=15
DOWNLOAD_URL_TTL_MINUTES=30
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_FAILURES=5
ACCOUNT_LOCK_MINUTES=15
REQUEST_TIMEOUT_MS=15000
GRACEFUL_SHUTDOWN_MS=10000
BODY_LIMIT_KB=200
API_RATE_LIMIT_PER_MINUTE=240
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
ALLOW_MULTIPLE_ACTIVE_SESSIONS=false
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
DEBUG_MODE=false
LOG_LEVEL=info
TRUST_PROXY=false
EMAIL_FROM=ops@example.com
SENTRY_DSN=
VITE_API_BASE_URL=/api
VITE_SENTRY_DSN=
